<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ uses the SplashScreen API and ignores legacy
         windowBackground. The system splash is constrained to a single
         solid background colour with one centered icon — we pick a
         navy that visually blends into the Flutter LojraLogjikeSplash
         gradient, and use the gold LL monogram as the icon so the
         system splash already reads as "LojraLogjike". -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo_ll</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>
</resources>
