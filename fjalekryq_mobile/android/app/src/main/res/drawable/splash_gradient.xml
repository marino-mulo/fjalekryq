<?xml version="1.0" encoding="utf-8"?>
<!-- Vertical gradient that mirrors the Flutter AppBackground gradient:
     #0C1F4A → #123B86 → #07152F (top → middle → bottom). Used as the
     pre-API 31 launch window background so the system splash blends
     into the Flutter splash. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
       android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#0C1F4A"
        android:centerColor="#123B86"
        android:endColor="#07152F" />
</shape>
